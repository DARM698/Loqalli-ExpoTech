generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Perfil {
  id        String   @id @default(uuid())
  nombre    String
  rol       String
  ubicacion String?
  createdAt DateTime @default(now())
}


model MicroExperience {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float
  imageUrl    String
  location    String
  hostId      String   
  createdAt   DateTime @default(now())
}