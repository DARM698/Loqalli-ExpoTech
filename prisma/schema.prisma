generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  fullName     String
  age          Int
  email        String        @unique
  password     String
  bio          String?
  role         Role
  createdAt    DateTime      @default(now())
  bankInfo     BankInfo?
  Booking      Booking[]
  experiences  Experience[]
  verification Verification?
}

model Experience {
  id              String        @id @default(cuid())
  title           String
  category        String
  description     String
  pricePerPerson  Float
  maxParticipants Int
  address         String
  lat             Float?
  lng             Float?
  days            String[]
  slots           String[]
  images          String[]
  status          String        @default("DRAFT")
  createdAt       DateTime      @default(now())
  hostId          String
  paymentMethod   PaymentMethod @default(CASH)
  Booking         Booking[]
  host            User          @relation(fields: [hostId], references: [id])
}

model BankInfo {
  id            String   @id @default(cuid())
  userId        String   @unique
  accountHolder String
  bankName      String
  accountType   String
  accountNumber String
  routingNumber String
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model Verification {
  id        String             @id @default(cuid())
  userId    String             @unique
  faceImage String?
  document  String?
  status    VerificationStatus @default(PENDING)
  verified  Boolean            @default(false)
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id])
}

model Booking {
  id           String        @id
  date         String
  time         String
  guests       Int
  status       BookingStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  experienceId String
  touristId    String
  Experience   Experience    @relation(fields: [experienceId], references: [id])
  User         User          @relation(fields: [touristId], references: [id])
}

enum Role {
  HOST
  TOURIST
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
}
