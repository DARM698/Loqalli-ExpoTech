generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  fullName     String
  age          Int
  email        String        @unique
  password     String
  bio          String?
  profileImage String?       // <-- AÑADIDO: Para la foto de perfil después del login
  role         Role
  createdAt    DateTime      @default(now())
  bankInfo     BankInfo?
  Booking      Booking[]
  experiences  Experience[]
  verification Verification?
  transactions Transaction[] // <-- AÑADIDO: Relación con las transacciones donde participa el usuario
}

model Experience {
  id              String        @id @default(cuid())
  title           String
  category        String
  description     String
  pricePerPerson  Float
  maxParticipants Int
  address         String
  lat             Float?
  lng             Float?
  days            String[]
  slots           String[]
  images          String[]
  status          String        @default("DRAFT")
  createdAt       DateTime      @default(now())
  hostId          String
  paymentMethod   PaymentMethod @default(CASH)
  Booking         Booking[]
  host            User          @relation(fields: [hostId], references: [id])
}

model BankInfo {
  id            String   @id @default(cuid())
  userId        String   @unique
  accountHolder String
  bankName      String
  accountType   String
  accountNumber String
  routingNumber String
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model Verification {
  id        String             @id @default(cuid())
  userId    String             @unique
  faceImage String?
  document  String?
  status    VerificationStatus @default(PENDING)
  verified  Boolean            @default(false)
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id])
}

model Booking {
  id           String        @id @default(cuid()) // Añadido default cuid() por consistencia
  date         String
  time         String
  guests       Int
  status       BookingStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  experienceId String
  touristId    String
  Experience   Experience    @relation(fields: [experienceId], references: [id])
  User         User          @relation(fields: [touristId], references: [id])
  Transaction  Transaction[] // <-- AÑADIDO: Una reserva puede gatillar transacciones
}

// <-- NUEVO MODELO: Para controlar los flujos de dinero (5% y 95%)
model Transaction {
  id              String            @id @default(cuid())
  bookingId       String
  booking         Booking           @relation(fields: [bookingId], references: [id])
  touristId       String
  tourist         User              @relation(fields: [touristId], references: [id])
  
  totalAmount     Float             // Monto total pagado por el turista (Ej: $100)
  loqalliFee      Float             // Tu 5% (Ej: $5)
  hostPayout      Float             // El 95% para el host (Ej: $95)
  
  paymentStatus   TransactionStatus @default(PENDING)
  payoutStatus    PayoutStatus      @default(NOT_APPLICABLE) // Para controlar si ya le transferiste al Host
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

enum Role {
  HOST
  TOURIST
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
}

// <-- NUEVOS ENUMS: Para la lógica de negocio del dinero
enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PayoutStatus {
  NOT_APPLICABLE // Si el host eligió CASH, Loqalli no tiene que transferirle nada.
  PENDING        // Si es TRANSFER, queda pendiente hasta que tu sistema/pasarela le pague.
  PAID           // Ya se le envió su 95%.
}